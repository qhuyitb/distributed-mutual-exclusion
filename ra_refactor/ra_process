"""
distributed/ra_process.py
--------------------------
Cài đặt thuật toán Ricart–Agrawala cho đồng bộ truy cập CS phân tán.

Thuật toán:
  - Không có server trung tâm. Mỗi process nói chuyện trực tiếp với nhau.
  - Dựa trên Lamport Clock để xác định thứ tự ưu tiên.

3 quy tắc cốt lõi:
  1. Khi muốn vào CS  → broadcast REQUEST(ts, pid) đến TẤT CẢ, chờ đủ REPLY.
  2. Khi nhận REQUEST → nếu mình không WANTED/HELD: REPLY ngay.
                         nếu mình đang WANTED/HELD và request của mình ưu tiên hơn
                         (ts nhỏ hơn, hoặc ts bằng nhau nhưng pid nhỏ hơn): defer.
                         ngược lại: REPLY ngay.
  3. Khi ra khỏi CS  → gửi REPLY cho tất cả pid trong deferred_queue.

Chỉ cần dùng:
    from common import BaseProcess, PeerInfo, State
    class RAProcess(BaseProcess): ...
"""

import threading
import time
import sys, os

# Thêm thư mục GỐC của project (chứa cả common/ và ra_refactor/)
# __file__ = .../ra_refactor/ra_process.py
# os.path.dirname(..., 2 lần) = thư mục gốc project
ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if ROOT not in sys.path:
    sys.path.insert(0, ROOT)

from common import BaseProcess, PeerInfo, State
from common import msg_request, msg_reply, msg_release, MsgType


class RAProcess(BaseProcess):
    """
    Process cài đặt thuật toán Ricart–Agrawala.

    Kế thừa BaseProcess: socket server, Lamport clock, send/broadcast
    đã được xử lý sẵn. Class này chỉ cần override 3 hàm:
      - _handle_message()
      - request_cs()
      - release_cs()
    """

    def __init__(self, pid: int, host: str, port: int, peers: list):
        # Khởi tạo BaseProcess (socket server, clock, stats...)
        super().__init__(pid, host, port, peers)

        # ── Dữ liệu riêng của Ricart–Agrawala ──────────────────────────
        # Số REPLY cần nhận = số peer (N - 1)
        self.n_peers = len(peers)

        # Đếm REPLY đã nhận cho lần request hiện tại
        self.reply_count = 0
        self._reply_lock = threading.Lock()

        # Timestamp khi gửi REQUEST (dùng để so sánh ưu tiên)
        self.request_ts = 0

        # Danh sách pid cần gửi REPLY sau khi ra CS
        self.deferred: list[int] = []
        self._defer_lock = threading.Lock()

    # ─────────────────────────────────────────────────────────────────
    # PHẦN 1: Xin vào Critical Section
    # ─────────────────────────────────────────────────────────────────

    def request_cs(self) -> None:
        """
        Yêu cầu vào CS. Hàm BLOCK đến khi được cấp phép.

        Luồng:
          1. Chuyển sang WANTED
          2. Ghi nhớ timestamp
          3. Broadcast REQUEST đến tất cả peer
          4. Chờ cs_event (được set khi reply_count == n_peers)
          5. Chuyển sang HELD → vào CS
        """
        # Bước 1-2: Đánh dấu WANTED, tăng clock, ghi timestamp
        with self.state_lock:
            self.state = State.WANTED
            ts = self.tick()
            self.request_ts = ts

        self.log(f"Xin vào CS với timestamp={ts}")

        # Bước 3: Broadcast REQUEST đến tất cả peer
        self.cs_event.clear()
        with self._reply_lock:
            self.reply_count = 0

        payload = msg_request(sender_id=self.pid, timestamp=ts)
        self.broadcast(payload)
        self.log(f"Đã broadcast REQUEST đến {self.n_peers} peer")

        # Bước 4: Chờ đủ REPLY từ tất cả peer (blocking)
        self.cs_event.wait()

        # Bước 5: Được cấp phép → vào CS
        with self.state_lock:
            self.state = State.HELD
        self.log("Được cấp phép → vào CS")

    # ─────────────────────────────────────────────────────────────────
    # PHẦN 2: Ra khỏi Critical Section
    # ─────────────────────────────────────────────────────────────────

    def release_cs(self) -> None:
        """
        Ra khỏi CS và gửi REPLY cho tất cả các process đang bị defer.

        Luồng:
          1. Chuyển sang RELEASED
          2. Gửi REPLY đến tất cả pid trong deferred_queue
          3. Xóa deferred_queue
        """
        with self.state_lock:
            self.state = State.RELEASED

        # Lấy toàn bộ deferred list và clear (atomic)
        with self._defer_lock:
            to_reply = list(self.deferred)
            self.deferred.clear()

        if to_reply:
            self.log(f"Ra CS, gửi REPLY đến deferred: {to_reply}")
        else:
            self.log("Ra CS (không có ai bị defer)")

        ts = self.tick()
        payload = msg_reply(sender_id=self.pid, timestamp=ts)
        for pid in to_reply:
            self.send_to_pid(pid, payload, async_send=True)

    # ─────────────────────────────────────────────────────────────────
    # PHẦN 3: Xử lý message nhận được (trái tim của thuật toán)
    # ─────────────────────────────────────────────────────────────────

    def _handle_message(self, msg: dict, conn) -> None:
        """
        Dispatcher: phân loại và xử lý message theo type.
        Được gọi tự động bởi BaseProcess khi có kết nối mới đến.
        """
        mtype = msg["type"]

        if mtype == MsgType.REQUEST:
            self._on_request(msg)
        elif mtype == MsgType.REPLY:
            self._on_reply(msg)
        elif mtype == MsgType.RELEASE:
            self._on_release(msg)
        else:
            self.log(f"Nhận message không rõ type: {mtype}", level="warning")

    def _on_request(self, msg: dict) -> None:
        """
        Xử lý REQUEST từ process khác.

        Quyết định có REPLY ngay hay defer:
          - Nếu mình HELD → defer (đang dùng CS, chưa thể nhường)
          - Nếu mình WANTED và request của MÌNH ưu tiên hơn → defer
          - Còn lại → REPLY ngay
        """
        sender_pid = msg["sender"]
        sender_ts  = msg["timestamp"]

        self.log(f"Nhận REQUEST từ P{sender_pid} (ts={sender_ts})")

        with self.state_lock:
            current_state = self.state
            my_ts         = self.request_ts

        should_defer = False

        if current_state == State.HELD:
            # Mình đang trong CS → phải chờ mình ra
            should_defer = True

        elif current_state == State.WANTED:
            # Cả hai đang muốn vào CS → so sánh ưu tiên
            # Ưu tiên cao hơn = timestamp nhỏ hơn
            # Nếu timestamp bằng nhau → pid nhỏ hơn thắng (tie-break)
            my_priority     = (my_ts,     self.pid)
            their_priority  = (sender_ts, sender_pid)
            should_defer    = (my_priority < their_priority)

        # State == RELEASED → REPLY ngay (không cần CS)

        if should_defer:
            with self._defer_lock:
                self.deferred.append(sender_pid)
            self.log(f"Defer REPLY đến P{sender_pid} "
                     f"(my_priority={my_ts},{self.pid} < "
                     f"their={sender_ts},{sender_pid}: {should_defer})")
        else:
            ts = self.tick()
            payload = msg_reply(sender_id=self.pid, timestamp=ts)
            self.send_to_pid(sender_pid, payload, async_send=True)
            self.log(f"REPLY ngay cho P{sender_pid}")

    def _on_reply(self, msg: dict) -> None:
        """
        Xử lý REPLY từ peer.
        Đếm số REPLY nhận được. Khi đủ N-1 → set cs_event → unblock request_cs().
        """
        sender_pid = msg["sender"]

        with self._reply_lock:
            self.reply_count += 1
            count = self.reply_count

        self.log(f"Nhận REPLY từ P{sender_pid} ({count}/{self.n_peers})")

        if count == self.n_peers:
            self.log("Đủ REPLY → được phép vào CS")
            self.cs_event.set()

    def _on_release(self, msg: dict) -> None:
        """
        Một số cài đặt gửi RELEASE khi ra CS thay vì REPLY.
        Trong R-A chuẩn thì không cần, nhưng xử lý phòng trường hợp
        peer dùng phiên bản hơi khác.
        """
        self.log(f"Nhận RELEASE từ P{msg['sender']} (bỏ qua trong R-A chuẩn)")


