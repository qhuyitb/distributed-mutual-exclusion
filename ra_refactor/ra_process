def _do_cs(proc, duration=5.0):
    print(f"\n  [{proc.pid}] → REQUEST gửi đến {len(proc.peers)} peer...")
    proc.request_cs()
    print(f"\n  [{proc.pid}] | TRONG CS | (giữ {duration}s)")
    proc.do_critical_section(duration=duration)
    proc.release_cs()
    print(f"\n  [{proc.pid}] → RELEASED, đã gửi REPLY cho deferred\n")

if __name__ == "__main__":
    import sys
    from common.config_loader import load_config, get_peers

    if len(sys.argv) < 2:
        print("Dùng: python ra_process.py <pid>")
        print("  Ví dụ: python ra_process.py 0")
        sys.exit(1)

    pid    = int(sys.argv[1])
    cfg    = load_config()          # đọc config.json tự động
    nodes  = cfg["nodes"]
    peers  = get_peers(nodes, pid)

    # Kiểm tra pid hợp lệ
    me = next((n for n in nodes if n.pid == pid), None)
    if me is None:
        print(f"Lỗi: pid={pid} không có trong config.json")
        sys.exit(1)

    proc = RAProcess(
        pid   = pid,
        host  = me.host,
        port  = me.port,
        peers = peers,
    )
    proc.start()

    print(f"\n  P{pid} | {me.host}:{me.port} | {len(peers)} peer")
    print(f"  Lệnh: [r] request CS | [s] stats | [q] quit\n")

    while True:
        try:
            cmd = input(f"P{pid}> ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            break

        if cmd == "r":
            threading.Thread(target=_do_cs,
                args=(proc, cfg["cs_duration"]), daemon=True).start()
        elif cmd == "s":
            print(f"  {proc.get_stats()} | state={proc.state} | clock={proc.clock}")
        elif cmd == "q":
            break

    proc.stop()
