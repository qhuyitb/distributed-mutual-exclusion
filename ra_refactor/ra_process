def run_demo(n_processes: int = 3, base_port: int = 25000):
    """
    Chạy demo N process Ricart–Agrawala trên localhost.
    Mỗi process sẽ lần lượt vào CS 1 lần.
    In log ra màn hình để thấy luồng REQUEST/REPLY.
    """
    print(f"\n{'='*55}")
    print(f"  Demo Ricart–Agrawala với {n_processes} process")
    print(f"{'='*55}\n")

    # Tạo danh sách thông tin tất cả process
    all_info = [
        PeerInfo(pid=i, host="127.0.0.1", port=base_port + i)
        for i in range(n_processes)
    ]

    # Tạo mỗi process với danh sách peer (trừ chính mình)
    processes = []
    for info in all_info:
        peers = [p for p in all_info if p.pid != info.pid]
        proc  = RAProcess(
            pid   = info.pid,
            host  = info.host,
            port  = info.port,
            peers = peers,
        )
        processes.append(proc)

    # Khởi động server socket cho tất cả
    for proc in processes:
        proc.start()
    time.sleep(0.5)  # đợi socket sẵn sàng

    # Mỗi process chạy trong thread riêng
    # Thứ tự cố ý ngẫu nhiên để thấy thuật toán phân xử
    results = {}

    def worker(proc: RAProcess):
        try:
            t_start = time.time()
            proc.request_cs()
            t_enter = time.time()

            proc.do_critical_section(duration=0.3)

            proc.release_cs()
            t_end = time.time()

            results[proc.pid] = {
                "wait_time" : round(t_enter - t_start, 3),
                "cs_time"   : round(t_end - t_enter, 3),
            }
        except Exception as e:
            proc.log(f"Lỗi: {e}", level="error")

    threads = [
        threading.Thread(target=worker, args=(proc,), daemon=True)
        for proc in processes
    ]

    # Khởi động lệch nhau 100ms để thấy cạnh tranh
    for i, t in enumerate(threads):
        t.start()
        time.sleep(0.05)

    for t in threads:
        t.join(timeout=30)

    # In kết quả
    print(f"\n{'='*55}")
    print("  Kết quả:")
    print(f"{'─'*55}")
    for pid in sorted(results):
        r = results[pid]
        stats = processes[pid].get_stats()
        print(f"  P{pid}: chờ={r['wait_time']}s | "
              f"msg_sent={stats['msg_sent']} | "
              f"msg_recv={stats['msg_recv']}")

    total_msgs = sum(p.get_stats()["msg_total"] for p in processes)
    print(f"{'─'*55}")
    print(f"  Tổng message toàn mạng: {total_msgs}")
    print(f"  Lý thuyết R-A: {n_processes} * 2 * ({n_processes}-1) = "
          f"{n_processes * 2 * (n_processes - 1)} message")
    print(f"{'='*55}\n")

    for proc in processes:
        proc.stop()


def run_node(pid: int, n: int, base_port: int = 25000):
    """
    Chạy 1 process ở chế độ interactive.
    Mỗi terminal chạy 1 lệnh này với pid khác nhau.
    """
    all_info = [
        PeerInfo(pid=i, host="127.0.0.1", port=base_port + i)
        for i in range(n)
    ]
    peers = [p for p in all_info if p.pid != pid]

    proc = RAProcess(
        pid=pid,
        host="127.0.0.1",
        port=base_port + pid,
        peers=peers,
    )
    proc.start()

    print(f"\n  P{pid} đã khởi động | cổng={base_port + pid}")
    print(f"  Lệnh: [r] request CS  |  [q] thoát\n")

    while True:
        try:
            cmd = input(f"P{pid}> ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            break

        if cmd == "r":
            # Chạy trong thread riêng để không block input
            threading.Thread(target=_do_cs, args=(proc,), daemon=True).start()
        elif cmd == "q":
            break
        elif cmd == "s":
            print(f"  Stats: {proc.get_stats()}")
            print(f"  State: {proc.state} | clock: {proc.clock}")
        else:
            print("  Lệnh: r=request, s=stats, q=quit")

    proc.stop()


